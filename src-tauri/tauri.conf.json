{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AnyForge",
  "version": "1.0.4",
  "identifier": "com.xiaole.anyforge",
  "build": {
    "beforeDevCommand": "node scripts/build.mjs && python3 -m http.server 1420 -d dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/build.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AnyForge 1.0.4",
        "width": 480,
        "height": 532,
        "minWidth": 440,
        "minHeight": 532
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
